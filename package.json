{
  "name": "dontopedia",
  "private": true,
  "version": "0.0.1",
  "description": "An open, paraconsistent wiki built on donto. Every fact has a context, a time, and an opinion.",
  "license": "Apache-2.0 OR MIT",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}
