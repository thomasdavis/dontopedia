# dontosrv — donto's HTTP sidecar (from /home/ajax/repos/donto, crate: dontosrv)
DONTOSRV_URL=http://localhost:7878
NEXT_PUBLIC_DONTOSRV_URL=http://localhost:7878

# agent-runner — starts research sessions + streams progress
AGENT_RUNNER_URL=http://localhost:4001

# Temporal — event orchestration for research + extraction workflows
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=dontopedia

# Extraction model — Dontopedia uses gpt-4.1-mini
OPENAI_API_KEY=
EXTRACTION_MODEL=gpt-4.1-mini

# Codex research agent — the worker spawns per-session sandbox containers via
# docker.sock. Run `codex login` once on the host so the sandbox inherits
# credentials; OPENAI_API_KEY can also be used as a fallback auth path.
CODEX_SANDBOX_IMAGE=dontopedia-codex-sandbox:latest
CODEX_SANDBOX_NETWORK=dontopedia_default

# Anthropic is still used by document transcription / vision flows.
ANTHROPIC_API_KEY=

# Postgres — shared by donto, temporal, and the dontopedia app schema.
DATABASE_URL=postgres://donto:donto@localhost:55432/donto

# Grafana (bound to 127.0.0.1:3001 by default)
GRAFANA_USER=admin
GRAFANA_PASSWORD=dontopedia

# Postgres backups (optional — leave S3_* blank to keep local-only)
BACKUP_RETAIN_DAYS=14
S3_ENDPOINT=
S3_BUCKET=
S3_PREFIX=dontopedia/pg
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Public origin — absolute URLs + metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
